DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobfinder_ai?schema=public"

# Optional auth stub controls
NEXT_PUBLIC_AUTH_MODE="stub"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
DEMO_USER_EMAIL="demo@jobfinder.ai"
DEMO_USER_PASSWORD="password123"

# Optional AI providers. If absent, the app uses local fallback generation.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_PROVIDER="local"

# Optional app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional email alerts. If unset, alerts are printed in local fallback mode.
EMAIL_PROVIDER="local"
ALERT_EMAIL_TO="you@example.com"
EMAIL_FROM="JobFinder AI <alerts@example.com>"
RESEND_API_KEY=""

# Refresh behavior
HIGH_MATCH_THRESHOLD="80"
JOB_REFRESH_TIMEOUT_MS="15000"
CRON_SECRET="replace-with-a-long-random-cron-secret"
